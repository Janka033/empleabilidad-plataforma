# ════════════════════════════════════════════════════════════════
# EmpleoUni — Variables de entorno
# Copia este archivo a `.env` y completa los valores para producción.
# En desarrollo local puedes dejarlo vacío: docker-compose usa los
# valores por defecto (${VAR:-default}).
# ════════════════════════════════════════════════════════════════

# ── Seguridad ────────────────────────────────────────────────────
# OBLIGATORIO en producción. Debe ser el MISMO en todos los servicios.
# Genera uno con: openssl rand -hex 32
JWT_SECRET=empleouni_secret_dev_change_in_prod

# Contraseña de PostgreSQL (la misma para la BD y todos los servicios)
DB_PASSWORD=postgres

# development | production
NODE_ENV=development

# ── URL pública del frontend ─────────────────────────────────────
# Usada en los enlaces de los correos (restablecer contraseña, etc.)
FRONTEND_URL=http://localhost:3000

# ── URLs públicas de las APIs (se incrustan en el build del frontend) ──
# En la nube apunta a los dominios/hosts públicos de cada microservicio.
NEXT_PUBLIC_AUTH_URL=http://localhost:3001
NEXT_PUBLIC_PERFILES_URL=http://localhost:3002
NEXT_PUBLIC_VACANTES_URL=http://localhost:3003
NEXT_PUBLIC_MATCHING_URL=http://localhost:3004
NEXT_PUBLIC_PRACTICAS_URL=http://localhost:3005
NEXT_PUBLIC_ANALYTICS_URL=http://localhost:3006
NEXT_PUBLIC_AUDIT_URL=http://localhost:3007

# ── Inicio de sesión con Google ──────────────────────────────────
# Crea un "OAuth 2.0 Client ID" (tipo: Web) en https://console.cloud.google.com/apis/credentials
# Authorized JavaScript origins: tu FRONTEND_URL (p. ej. http://localhost:3000 y tu dominio prod)
# El MISMO Client ID va en ambas variables (frontend y backend).
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_ID=

# ── Correo SMTP (restablecimiento de contraseña + notificaciones) ──
# Desarrollo: déjalo vacío → usa Mailpit (UI en http://localhost:8025).
# Producción: configura un proveedor real (SendGrid, Mailgun, Gmail, SES…).
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
MAIL_FROM=EmpleoUni <no-reply@empleouni.co>
