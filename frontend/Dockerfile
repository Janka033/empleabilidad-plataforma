FROM node:20-alpine AS deps
WORKDIR /app
COPY package*.json ./
RUN npm ci

FROM node:20-alpine AS builder
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY . .

# Variables necesarias en tiempo de build para Next.js
ARG NEXT_PUBLIC_AUTH_URL=http://localhost:3001
ARG NEXT_PUBLIC_PERFILES_URL=http://localhost:3002
ARG NEXT_PUBLIC_VACANTES_URL=http://localhost:3003
ARG NEXT_PUBLIC_MATCHING_URL=http://localhost:3004
ARG NEXT_PUBLIC_PRACTICAS_URL=http://localhost:3005
ARG NEXT_PUBLIC_ANALYTICS_URL=http://localhost:3006
ARG NEXT_PUBLIC_AUDIT_URL=http://localhost:3007
ARG NEXT_PUBLIC_GOOGLE_CLIENT_ID=

ENV NEXT_PUBLIC_AUTH_URL=$NEXT_PUBLIC_AUTH_URL
ENV NEXT_PUBLIC_PERFILES_URL=$NEXT_PUBLIC_PERFILES_URL
ENV NEXT_PUBLIC_VACANTES_URL=$NEXT_PUBLIC_VACANTES_URL
ENV NEXT_PUBLIC_MATCHING_URL=$NEXT_PUBLIC_MATCHING_URL
ENV NEXT_PUBLIC_PRACTICAS_URL=$NEXT_PUBLIC_PRACTICAS_URL
ENV NEXT_PUBLIC_ANALYTICS_URL=$NEXT_PUBLIC_ANALYTICS_URL
ENV NEXT_PUBLIC_AUDIT_URL=$NEXT_PUBLIC_AUDIT_URL
ENV NEXT_PUBLIC_GOOGLE_CLIENT_ID=$NEXT_PUBLIC_GOOGLE_CLIENT_ID

RUN npm run build

FROM node:20-alpine AS runner
WORKDIR /app
ENV NODE_ENV=production
COPY --from=builder /app/.next-build/standalone ./
COPY --from=builder /app/.next-build/static ./.next-build/static
COPY --from=builder /app/public ./public
EXPOSE 3000
CMD ["node", "server.js"]
